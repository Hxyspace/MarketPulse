{
  "name": "market-pulse",
  "version": "0.1.0",
  "description": "量化市场监控面板 — 红利罗盘 + 债市晴雨表 + 基金温度计",
  "main": "dist/index.js",
  "bin": {
    "market-pulse": "dist/index.js"
  },
  "files": [
    "dist",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && vite build",
    "postbuild": "node -e \"const fs=require('fs');fs.cpSync('src/data','dist/data',{recursive:true})\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "echarts": "^6.0.0",
    "express": "^4.21.0",
    "get-port": "^7.2.0",
    "internal-ip": "^9.0.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.10"
  }
}
